# Paste these into Railway's "Variables" tab. Real IDs are pre-filled;
# the 3 secrets (marked ⚠) you copy in yourself.

# ====== Whop (Locke Dynasty Holdings) ======
WHOP_API_KEY=apik_xxx                         # ⚠ your Owner key (regenerate fresh, then paste)
WHOP_APP_ID=                                  # leave blank for a Company API key
WHOP_COMPANY_ID=biz_CPVXi316CCJ4iS            # ✓ filled
WHOP_WEBHOOK_SECRET=whsec_xxx                 # ⚠ from Whop > Developer > Webhooks (we create this next)
WHOP_PRODUCT_EXTERNAL_ID=shapedrops-store     # ✓ the product dynamic checkouts attach to
STATEMENT_DESCRIPTOR=TRUEHEALTH               # ✓ shows on the buyer's card statement

# ====== Shopify (TrueHealthic) ======
SHOPIFY_STORE=dsf8fr-wr.myshopify.com         # ✓ filled
SHOPIFY_API_KEY=f50a2851e79ab16428371b6e3b1b23b1   # ✓ Whop Bridge app Client ID
SHOPIFY_API_SECRET=xxx                         # ⚠ Whop Bridge app Secret (Dev Dashboard > Settings > reveal)
SHOPIFY_SCOPES=write_orders,read_products,read_orders
SHOPIFY_API_VERSION=2025-01
SHOPIFY_ADMIN_TOKEN=                           # leave blank — auto-captured when you visit HOST_URL/auth

# ====== Server ======
HOST_URL=https://your-app.up.railway.app       # set to your Railway URL after the first deploy
ALLOWED_ORIGIN=https://shoptruehealth.com
PORT=3000
